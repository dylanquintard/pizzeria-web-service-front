# Build-time variables for the React app
REACT_APP_API_BASE_URL=https://api.your-domain.tld/api
REACT_APP_SITE_URL=https://www.your-domain.tld
REACT_APP_INSTAGRAM_URL=https://instagram.com/your-account

# Optional branding
# REACT_APP_BRAND_LOGO_URL=https://cdn.your-domain.tld/logo.webp

# Runtime variables for the Node SEO/SPA server
SEO_BACKEND_API_URL=https://api.your-domain.tld/api
CANONICAL_SITE_URL=https://www.your-domain.tld
SEO_CACHE_TTL_MS=300000
SEO_FETCH_TIMEOUT_MS=6000

# Usually injected by the hosting platform
# PORT=10000
