PORT=3000

# Public (front) config examples — replace with your own values.
REACT_APP_API_BASE_URL=https://your-backend.example.com/api
REACT_APP_SOCKET_URL=https://your-backend.example.com
REACT_APP_INSTAGRAM_URL=https://instagram.com/youraccount
REACT_APP_SITE_URL=https://your-site.example.com

# SEO / SSR config examples
SEO_BACKEND_API_URL=https://your-backend.example.com/api
CANONICAL_SITE_URL=https://your-site.example.com
SEO_CACHE_TTL_MS=300000
SEO_FETCH_TIMEOUT_MS=6000
